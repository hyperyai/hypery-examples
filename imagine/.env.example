# Hypery gateway
NEXT_PUBLIC_API_URL=https://your-gateway.example.com/api/v1
NEXT_PUBLIC_CORE_API_URL=https://your-gateway.example.com
NEXT_PUBLIC_AUTH_URL=https://your-gateway.example.com

# OAuth client
NEXT_PUBLIC_OAUTH_CLIENT_ID=your_client_id
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3007/auth/callback

# ⚠️ SERVER-SIDE ONLY — this demo shows the confidential-client (backend proxy)
# pattern: the token exchange happens in an API route, so the secret stays on
# the server. NEVER expose this via a NEXT_PUBLIC_* variable, and never commit
# a real value. See INTEGRATION_PATTERNS.md at the repo root.
OAUTH_CLIENT_SECRET=your_client_secret
