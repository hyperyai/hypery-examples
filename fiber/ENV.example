# Hypery OAuth Configuration
NEXT_PUBLIC_OAUTH_CLIENT_ID=your_oauth_client_id_here
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3005/callback
NEXT_PUBLIC_AUTH_URL=http://localhost:3001

# Note: Get your OAuth credentials from your Hypery Hub dashboard
# 1. Go to https://hypery.com/dashboard/apps
# 2. Create a new app or use existing one
# 3. Copy the Client ID
# 4. Set the redirect URI to http://localhost:3005/callback (or your production URL)

