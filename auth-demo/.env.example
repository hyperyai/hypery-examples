# Hypery gateway (OAuth + API host)
NEXT_PUBLIC_AUTH_URL=https://your-gateway.example.com

# OAuth (public PKCE client — no secret needed)
NEXT_PUBLIC_OAUTH_CLIENT_ID=your_client_id
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3003/callback

# Optional: app id of a marketplace seller to demo "buy with Hypery" checkout
NEXT_PUBLIC_DEMO_SELLER_APP_ID=
