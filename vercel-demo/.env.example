# Hypery gateway
NEXT_PUBLIC_API_URL=https://your-gateway.example.com/api/v1
NEXT_PUBLIC_AUTH_URL=https://your-gateway.example.com

# OAuth (public PKCE client — no secret needed)
NEXT_PUBLIC_OAUTH_CLIENT_ID=your_client_id
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3005/callback

# Optional: a Hypery API key (ak_...) for key-based (non-OAuth) requests.
# NOTE: NEXT_PUBLIC_* values are visible in the browser bundle — only use a
# key you are comfortable exposing in a local demo, never a production key.
NEXT_PUBLIC_GATEWAY_API_KEY=
